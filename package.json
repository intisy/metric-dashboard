{
  "name": "metric-dashboard",
  "version": "1.2.0",
  "description": "Credit and billing dashboard plugin for OpenCode and Claude Code, with Firebase sync.",
  "main": "dist/index.js",
  "type": "module",
  "license": "MIT",
  "author": "intisy",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/intisy-ai/metric-dashboard.git"
  },
  "keywords": [
    "opencode",
    "claude",
    "credit",
    "dashboard",
    "plugin",
    "billing"
  ],
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "claudeHub": {
    "daemon": {
      "script": "dist/index.js",
      "port": 3456,
      "healthCheckUrl": "http://127.0.0.1:3456/",
      "runtime": "node"
    }
  },
  "scripts": {
    "build": "node scripts/build.js",
    "test": "npm run build && vitest run",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^0.15.30",
    "esbuild": "^0.24.0",
    "vitest": "^3.2.6"
  }
}
